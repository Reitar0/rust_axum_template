# Образец переменных окружения. Скопируй в .env и при необходимости поправь:
#   cp .env.example .env   (Linux/macOS)
#   Copy-Item .env.example .env   (PowerShell)

# Строка подключения к PostgreSQL (обязательна).
DATABASE_URL=postgres://app:app@localhost:5432/app

# Адрес HTTP-сервера (необязательно, дефолт 0.0.0.0:8080).
SERVER_ADDR=0.0.0.0:8080

# Уровень логирования (необязательно, дефолт info): error|warn|info|debug|trace.
LOG_LEVEL=info
