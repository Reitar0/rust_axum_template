# Образец переменных окружения. Скопируй в .env и при необходимости поправь:
#   cp .env.example .env            (Linux/macOS)
#   Copy-Item .env.example .env     (PowerShell)
#
# Чтобы запускать несколько проектов из шаблона ОДНОВРЕМЕННО, задай в каждом
# уникальные порты. Например: проект A — 5432/8080, проект B — 5433/8081.

# Хост-порт PostgreSQL (проброс наружу; используется в compose.yaml).
DB_PORT=5432

# Строка подключения к PostgreSQL (обязательна). Порт должен совпадать с DB_PORT.
DATABASE_URL=postgres://app:app@localhost:5432/app

# Адрес HTTP-сервера (порт приложения).
SERVER_ADDR=0.0.0.0:8080

# Уровень логирования: error|warn|info|debug|trace.
LOG_LEVEL=info

# Разрешённые CORS-origins (список через запятую). Дев-дефолт — порты фронта.
# В проде задаётся окружением деплоя реальным доменом фронта (не *, не localhost).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
